# ══════════════════════════════════════════════════════════════════════════════
# ClinicaBot — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no Git!
# ══════════════════════════════════════════════════════════════════════════════

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_TOKEN=        # Token de acesso gerado no Meta for Developers
WHATSAPP_PHONE_ID=     # ID do número de telefone (Phone Number ID)
VERIFY_TOKEN=          # Qualquer string que você escolher para verificar o webhook
APP_SECRET=            # App Secret do seu app na Meta (usado no HMAC)

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=        # Chave da API do Google AI Studio

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=          # URL do projeto Supabase (ex: https://xxx.supabase.co)
SUPABASE_SERVICE_KEY=  # Service Role Key (Settings → API → service_role)

# ── Segurança (CPF) ─────────────────────────────────────────────────────────
CPF_ENCRYPTION_KEY=    # Chave de 32 bytes em hexadecimal (64 caracteres)
                       # Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development   # Mude para "production" no deploy

# ── Painel Admin (Produção) ──────────────────────────────────────────────────
ADMIN_DASHBOARD_URL=   # URL do painel administrativo (CORS em produção)
